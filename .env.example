# ========================================
# Database Configuration
# ========================================
# PostgreSQL database connection settings
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=liftcrew

# ========================================
# Application Mode
# ========================================
# MODE: Application environment (DEV, STAGING, PRODUCTION)
MODE=DEV
# RUN_MIGRATIONS: Automatically run database migrations on startup (true/false)
RUN_MIGRATIONS=true

# ========================================
# Redis Configuration
# ========================================
# Redis cache server connection settings
REDIS_HOST=localhost
REDIS_PORT=6379

# ========================================
# Neo4j Configuration
# ========================================
# Neo4j graph database connection settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ========================================
# JWT Configuration
# ========================================
# JWT_SECRET: Secret key for signing access tokens (use a strong, random string)
JWT_SECRET=your-secure-jwt-secret-here

# JWT_EXPIRY_SECONDS: Access token expiration time in seconds (default: 604800 = 7 days)
JWT_EXPIRY_SECONDS=604800

# JWT_REFRESH_SECRET: Secret key for signing refresh tokens (MUST be different from JWT_SECRET)
JWT_REFRESH_SECRET=your-secure-refresh-secret-here

# JWT_REFRESH_EXPIRY_SECONDS: Refresh token expiration time in seconds (default: 1209600 = 14 days)
JWT_REFRESH_EXPIRY_SECONDS=1209600

# ========================================
# Firebase Configuration
# ========================================
# Firebase service account credentials for authentication
# Paste your Firebase service account JSON as a single-line string
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n","client_email":"your-client-email@your-project.iam.gserviceaccount.com","client_id":"your-client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"your-cert-url"}

# ========================================
# Notification Configuration
# ========================================
# FCM_ENCRYPTION_KEY: 32-byte hex string for AES-256-GCM encryption of FCM tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FCM_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
